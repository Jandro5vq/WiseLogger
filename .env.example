# Required
SECRET_KEY=change_me_to_a_random_32_char_minimum_string
ADMIN_EMAIL=admin@example.com

# Optional — defaults shown
BASE_URL=http://localhost:3000
# Local dev: ./data/wiselogger.db  |  Docker: /data/wiselogger.db
DB_PATH=./data/wiselogger.db
PORT=3000
INVITATION_EXPIRY_HOURS=72
BACKUP_CRON=0 2 * * *
BACKUP_PATH=/data/backups
